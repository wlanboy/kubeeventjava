{
  "title": "Node Detail",
  "uid": "kube-node-detail",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",

  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource"
      },
      {
        "name": "host",
        "type": "query",
        "datasource": "$datasource",
        "label": "Node",
        "query": "label_values(kubeevents_node_total, host)"
      }
    ]
  },

  "panels": [

    {
      "type": "stat",
      "title": "Total Events on Node",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 3 },
      "targets": [
        {
          "expr": "sum(kubeevents_node_total{host=\"$host\"})"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events per Second (Node)",
      "datasource": "$datasource",
      "gridPos": { "x": 4, "y": 0, "w": 20, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_node_total{host=\"$host\"}[5m])",
          "legendFormat": "Events/s"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Node Object Events (Cluster Health)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_node_events_total{node=\"$host\"}[5m])",
          "legendFormat": "{{reason}} ({{type}})"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },

    {
      "type": "timeseries",
      "title": "Events by Component on Node",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "sum by (component) (rate(kubeevents_involved_total{host=\"$host\"}[5m]))",
          "legendFormat": "{{component}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events by Kind on Node",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "sum by (kind, type) (rate(kubeevents_involved_total{host=\"$host\"}[5m]))",
          "legendFormat": "{{kind}} ({{type}})"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events by Reason on Node",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "topk(10, sum by (reason, type) (rate(kubeevents_involved_total{host=\"$host\"}[5m])))",
          "legendFormat": "{{reason}} ({{type}})"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },

    {
      "type": "timeseries",
      "title": "Warning Events on Node",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "sum by (kind, reason) (rate(kubeevents_involved_total{host=\"$host\", type=\"Warning\"}[5m]))",
          "legendFormat": "{{kind}} / {{reason}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Spike Detection (Node)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "idelta(kubeevents_node_total{host=\"$host\"}[5m])",
          "legendFormat": "Spike"
        }
      ]
    }
  ]
}
