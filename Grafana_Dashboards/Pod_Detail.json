{
  "title": "Pod Detail",
  "uid": "kube-pod-detail",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },

  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource"
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": "$datasource",
        "label": "Namespace",
        "query": "label_values(kubeevents_pod_total, namespace)"
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": "$datasource",
        "label": "Pod",
        "query": "label_values(kubeevents_pod_total{namespace=\"$namespace\"}, pod)"
      }
    ]
  },

  "panels": [

    {
      "type": "stat",
      "title": "Total Events for Pod",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 3 },
      "targets": [
        {
          "expr": "sum(kubeevents_pod_total{namespace=\"$namespace\", pod=\"$pod\"})"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events per Second for Pod",
      "datasource": "$datasource",
      "gridPos": { "x": 4, "y": 0, "w": 20, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_pod_total{namespace=\"$namespace\", pod=\"$pod\"}[5m])",
          "legendFormat": "{{type}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events by Reason (Pod)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_involved_total{namespace=\"$namespace\", kind=\"Pod\"}[5m])",
          "legendFormat": "{{reason}} / {{type}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events by Component (Pod)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_involved_total{namespace=\"$namespace\", kind=\"Pod\"}[5m])",
          "legendFormat": "{{component}} / {{reason}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "CrashLoop / BackOff (Pod)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "increase(kubeevents_reason_total{namespace=\"$namespace\", reason=~\"BackOff|CrashLoopBackOff\"}[5m])",
          "legendFormat": "{{reason}} ({{type}})"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Scheduling Failures (FailedScheduling)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "increase(kubeevents_failedscheduling_total{namespace=\"$namespace\"}[5m])",
          "legendFormat": "FailedScheduling"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events by Node (Pod)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_node_total[5m])",
          "legendFormat": "{{host}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Spike Detection (Pod)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "idelta(kubeevents_pod_total{namespace=\"$namespace\", pod=\"$pod\"}[5m])",
          "legendFormat": "Spike"
        }
      ]
    },

    {
      "type": "stat",
      "title": "CrashLoopBackOff (Namespace)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 42, "w": 8, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_crashloopbackoff_total{namespace=\"$namespace\"})", "legendFormat": "CrashLoopBackOff" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      }
    },

    {
      "type": "stat",
      "title": "Unhealthy (Namespace)",
      "datasource": "$datasource",
      "gridPos": { "x": 8, "y": 42, "w": 8, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_unhealthy_total{namespace=\"$namespace\"})", "legendFormat": "Unhealthy" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      }
    },

    {
      "type": "stat",
      "title": "Failed (Namespace)",
      "datasource": "$datasource",
      "gridPos": { "x": 16, "y": 42, "w": 8, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_failed_total{namespace=\"$namespace\"})", "legendFormat": "Failed" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      }
    },

    {
      "type": "timeseries",
      "title": "Killing Events (Pod Termination) (5m Increase)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 45, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "increase(kubeevents_killing_total{namespace=\"$namespace\"}[5m])",
          "legendFormat": "{{namespace}} / {{kind}}"
        }
      ]
    }
  ]
}
