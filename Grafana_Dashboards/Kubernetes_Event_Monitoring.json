{
  "title": "Kubernetes Event Monitoring",
  "uid": "kube-events-main",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },

  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource"
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": "$datasource",
        "label": "Namespace",
        "query": "label_values(kubeevents_namespace_total, namespace)",
        "includeAll": true,
        "multi": true
      },
      {
        "name": "type",
        "type": "query",
        "datasource": "$datasource",
        "label": "Event Type",
        "query": "label_values(kubeevents_type_total, type)",
        "includeAll": true,
        "multi": true
      }
    ]
  },

  "panels": [

    {
      "type": "stat",
      "title": "Total Events",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 3 },
      "targets": [
        { "expr": "kubeevents_total" }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events per Second (Rate + Spike Detection)",
      "datasource": "$datasource",
      "gridPos": { "x": 4, "y": 0, "w": 20, "h": 6 },
      "targets": [
        { "expr": "rate(kubeevents_total[5m])", "legendFormat": "Events/s" },
        { "expr": "idelta(kubeevents_total[5m])", "legendFormat": "Spike Indicator" }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events by Type (Rate)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 6 },
      "targets": [
        { "expr": "rate(kubeevents_type_total{type=~\"$type\"}[5m])", "legendFormat": "{{type}}" }
      ]
    },

    {
      "type": "timeseries",
      "title": "Namespace × Type (Time Series Matrix)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "rate(kubeevents_namespace_type_total{namespace=~\"$namespace\", type=~\"$type\"}[5m])",
          "legendFormat": "{{namespace}} / {{type}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Warning Rate per Namespace (Spike Detection)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_namespace_type_total{type=\"Warning\", namespace=~\"$namespace\"}[5m])",
          "legendFormat": "{{namespace}}"
        },
        {
          "expr": "idelta(kubeevents_namespace_type_total{type=\"Warning\", namespace=~\"$namespace\"}[5m])",
          "legendFormat": "Spike Indicator"
        }
      ]
    },

    {
      "type": "stat",
      "title": "Watcher Errors",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 26, "w": 4, "h": 3 },
      "targets": [
        { "expr": "kubeevents_watch_errors_total" }
      ]
    },

    {
      "type": "stat",
      "title": "Watcher Restarts",
      "datasource": "$datasource",
      "gridPos": { "x": 4, "y": 26, "w": 4, "h": 3 },
      "targets": [
        { "expr": "kubeevents_watch_restarts_total" }
      ]
    },

    {
      "type": "stat",
      "title": "BackOff Events",
      "datasource": "$datasource",
      "gridPos": { "x": 8, "y": 26, "w": 4, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_backoff_total)", "legendFormat": "BackOff" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      }
    },

    {
      "type": "stat",
      "title": "OOMKilled Events",
      "datasource": "$datasource",
      "gridPos": { "x": 12, "y": 26, "w": 4, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_oomkilled_total)", "legendFormat": "OOMKilled" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      }
    },

    {
      "type": "stat",
      "title": "ImagePull Errors",
      "datasource": "$datasource",
      "gridPos": { "x": 16, "y": 26, "w": 4, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_imagepull_errors_total)", "legendFormat": "ImagePull" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 3 }
          ]}
        }
      }
    },

    {
      "type": "stat",
      "title": "FailedScheduling",
      "datasource": "$datasource",
      "gridPos": { "x": 20, "y": 26, "w": 4, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_failedscheduling_total)", "legendFormat": "FailedScheduling" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      }
    },

    {
      "type": "stat",
      "title": "CrashLoopBackOff",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 29, "w": 6, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_crashloopbackoff_total)", "legendFormat": "CrashLoopBackOff" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      }
    },

    {
      "type": "stat",
      "title": "Unhealthy",
      "datasource": "$datasource",
      "gridPos": { "x": 6, "y": 29, "w": 6, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_unhealthy_total)", "legendFormat": "Unhealthy" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      }
    },

    {
      "type": "stat",
      "title": "Failed Events",
      "datasource": "$datasource",
      "gridPos": { "x": 12, "y": 29, "w": 6, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_failed_total)", "legendFormat": "Failed" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      }
    },

    {
      "type": "stat",
      "title": "Evicted",
      "datasource": "$datasource",
      "gridPos": { "x": 18, "y": 29, "w": 6, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_evicted_total)", "legendFormat": "Evicted" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      }
    },

    {
      "type": "timeseries",
      "title": "Top Event Reasons",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 33, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "topk(10, sum by (reason, type) (rate(kubeevents_reason_total{namespace=~\"$namespace\", type=~\"$type\"}[5m])))",
          "legendFormat": "{{reason}} ({{type}})"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },

    {
      "type": "timeseries",
      "title": "Warning Reasons (Critical for Alerting)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 39, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "sum by (reason, namespace) (rate(kubeevents_reason_total{type=\"Warning\", namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{namespace}} / {{reason}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },

    {
      "type": "timeseries",
      "title": "Events by Component (kubelet / scheduler / controllers)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 45, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_component_total[5m])",
          "legendFormat": "{{component}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },

    {
      "type": "timeseries",
      "title": "Events by Node (Host)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 51, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_node_total[5m])",
          "legendFormat": "{{host}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },

    {
      "type": "timeseries",
      "title": "Events by Deployment",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 57, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_deployment_total[5m])",
          "legendFormat": "{{namespace}} / {{deployment}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    }
  ]
}
