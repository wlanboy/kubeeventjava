{
  "title": "Namespace Detail",
  "uid": "kube-namespace-detail",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },

  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource"
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": "$datasource",
        "label": "Namespace",
        "query": "label_values(kubeevents_namespace_total, namespace)"
      }
    ]
  },

  "panels": [

    {
      "type": "stat",
      "title": "Total Events in Namespace",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 3 },
      "targets": [
        { "expr": "kubeevents_namespace_total{namespace=\"$namespace\"}" }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events per Second",
      "datasource": "$datasource",
      "gridPos": { "x": 4, "y": 0, "w": 20, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_namespace_total{namespace=\"$namespace\"}[5m])",
          "legendFormat": "Events/s"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events by Type",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_namespace_type_total{namespace=\"$namespace\"}[5m])",
          "legendFormat": "{{type}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Spike Detection",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "idelta(kubeevents_namespace_total{namespace=\"$namespace\"}[5m])",
          "legendFormat": "Spike Indicator"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Top Event Reasons in Namespace",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "topk(10, sum by (reason, type) (rate(kubeevents_reason_total{namespace=\"$namespace\"}[5m])))",
          "legendFormat": "{{reason}} ({{type}})"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },

    {
      "type": "timeseries",
      "title": "Events by Node (Host)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "sum by (host) (rate(kubeevents_involved_total{namespace=\"$namespace\"}[5m]))",
          "legendFormat": "{{host}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events by Component (kubelet / scheduler / controllers)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "sum by (component) (rate(kubeevents_involved_total{namespace=\"$namespace\"}[5m]))",
          "legendFormat": "{{component}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Pod CrashLoop / BackOff (Namespace)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "increase(kubeevents_reason_total{namespace=\"$namespace\", reason=~\"BackOff|CrashLoopBackOff\"}[5m])",
          "legendFormat": "{{reason}} ({{type}})"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Pod Scheduling Failures (FailedScheduling)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 42, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "increase(kubeevents_failedscheduling_total{namespace=\"$namespace\"}[5m])",
          "legendFormat": "FailedScheduling"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Storage Events (PVC)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 48, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "increase(kubeevents_pvc_total{namespace=\"$namespace\"}[5m])",
          "legendFormat": "{{pvc}} ({{type}})"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Deployment Errors in Namespace",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 54, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "increase(kubeevents_deployment_total{namespace=\"$namespace\", type=\"Warning\"}[5m])",
          "legendFormat": "{{deployment}} / Warning"
        }
      ]
    },

    {
      "type": "stat",
      "title": "CrashLoopBackOff",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 60, "w": 6, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_crashloopbackoff_total{namespace=\"$namespace\"})", "legendFormat": "CrashLoopBackOff" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      }
    },

    {
      "type": "stat",
      "title": "Unhealthy",
      "datasource": "$datasource",
      "gridPos": { "x": 6, "y": 60, "w": 6, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_unhealthy_total{namespace=\"$namespace\"})", "legendFormat": "Unhealthy" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      }
    },

    {
      "type": "stat",
      "title": "Failed Events",
      "datasource": "$datasource",
      "gridPos": { "x": 12, "y": 60, "w": 6, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_failed_total{namespace=\"$namespace\"})", "legendFormat": "Failed" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      }
    },

    {
      "type": "stat",
      "title": "Evicted",
      "datasource": "$datasource",
      "gridPos": { "x": 18, "y": 60, "w": 6, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_evicted_total{namespace=\"$namespace\"})", "legendFormat": "Evicted" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      }
    }
  ]
}
