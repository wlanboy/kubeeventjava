{
  "title": "Deployment Detail",
  "uid": "kube-deployment-detail",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },

  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource"
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": "$datasource",
        "label": "Namespace",
        "query": "label_values(kubeevents_deployment_total, namespace)"
      },
      {
        "name": "deployment",
        "type": "query",
        "datasource": "$datasource",
        "label": "Deployment",
        "query": "label_values(kubeevents_deployment_total{namespace=\"$namespace\"}, deployment)"
      }
    ]
  },

  "panels": [

    {
      "type": "stat",
      "title": "Total Events for Deployment",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 3 },
      "targets": [
        {
          "expr": "sum(kubeevents_deployment_total{namespace=\"$namespace\", deployment=\"$deployment\"})"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events per Second (Deployment)",
      "datasource": "$datasource",
      "gridPos": { "x": 4, "y": 0, "w": 20, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_deployment_total{namespace=\"$namespace\", deployment=\"$deployment\"}[5m])",
          "legendFormat": "{{type}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "ReplicaSet Events",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_replicaset_total{namespace=\"$namespace\", replicaset=~\"$deployment.*\"}[5m])",
          "legendFormat": "{{replicaset}} ({{type}}) / {{reason}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Pod CrashLoop / BackOff (Deployment Pods)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "increase(kubeevents_involved_total{namespace=\"$namespace\", reason=~\"BackOff|CrashLoopBackOff\"}[5m])",
          "legendFormat": "{{reason}} ({{kind}})"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Pod Scheduling Failures (FailedScheduling)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "increase(kubeevents_failedscheduling_total{namespace=\"$namespace\"}[5m])",
          "legendFormat": "FailedScheduling"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events by Node (Deployment Pods)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "sum by (host) (rate(kubeevents_involved_total{namespace=\"$namespace\"}[5m]))",
          "legendFormat": "{{host}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events by Component (Deployment Pods)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "sum by (component) (rate(kubeevents_involved_total{namespace=\"$namespace\"}[5m]))",
          "legendFormat": "{{component}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events by Reason (Deployment)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "topk(10, sum by (reason, type) (rate(kubeevents_reason_total{namespace=\"$namespace\"}[5m])))",
          "legendFormat": "{{reason}} ({{type}})"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },

    {
      "type": "stat",
      "title": "CrashLoopBackOff (Namespace)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 42, "w": 8, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_crashloopbackoff_total{namespace=\"$namespace\"})", "legendFormat": "CrashLoopBackOff" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      }
    },

    {
      "type": "stat",
      "title": "Unhealthy (Namespace)",
      "datasource": "$datasource",
      "gridPos": { "x": 8, "y": 42, "w": 8, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_unhealthy_total{namespace=\"$namespace\"})", "legendFormat": "Unhealthy" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      }
    },

    {
      "type": "stat",
      "title": "Failed (Namespace)",
      "datasource": "$datasource",
      "gridPos": { "x": 16, "y": 42, "w": 8, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_failed_total{namespace=\"$namespace\"})", "legendFormat": "Failed" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      }
    },

    {
      "type": "timeseries",
      "title": "Direkte Deployment-Events (Rollout / Scaling)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 45, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_deployment_events_total{namespace=\"$namespace\", deployment=\"$deployment\"}[5m])",
          "legendFormat": "{{reason}} ({{type}})"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    }
  ]
}
