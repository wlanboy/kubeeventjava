{
  "title": "StatefulSet Detail",
  "uid": "kube-statefulset-detail",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",

  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource"
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": "$datasource",
        "label": "Namespace",
        "query": "label_values(kubeevents_statefulset_total, namespace)"
      },
      {
        "name": "statefulset",
        "type": "query",
        "datasource": "$datasource",
        "label": "StatefulSet",
        "query": "label_values(kubeevents_statefulset_total{namespace=\"$namespace\"}, statefulset)"
      }
    ]
  },

  "panels": [

    {
      "type": "stat",
      "title": "Total Events",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_statefulset_total{namespace=\"$namespace\", statefulset=\"$statefulset\"})" }
      ]
    },

    {
      "type": "stat",
      "title": "Warning Events",
      "datasource": "$datasource",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 3 },
      "targets": [
        { "expr": "sum(kubeevents_statefulset_total{namespace=\"$namespace\", statefulset=\"$statefulset\", type=\"Warning\"})" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      }
    },

    {
      "type": "timeseries",
      "title": "Events per Second",
      "datasource": "$datasource",
      "gridPos": { "x": 8, "y": 0, "w": 16, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_statefulset_total{namespace=\"$namespace\", statefulset=\"$statefulset\"}[5m])",
          "legendFormat": "{{type}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Normal vs Warning (5m Increase)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "increase(kubeevents_statefulset_total{namespace=\"$namespace\", statefulset=\"$statefulset\", type=\"Normal\"}[5m])",
          "legendFormat": "Normal"
        },
        {
          "expr": "increase(kubeevents_statefulset_total{namespace=\"$namespace\", statefulset=\"$statefulset\", type=\"Warning\"}[5m])",
          "legendFormat": "Warning"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events by Reason",
      "datasource": "$datasource",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum by (reason, type) (rate(kubeevents_involved_total{namespace=\"$namespace\", kind=\"StatefulSet\"}[5m]))",
          "legendFormat": "{{reason}} ({{type}})"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },

    {
      "type": "timeseries",
      "title": "Pod Events (StatefulSet Pods)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 7 },
      "targets": [
        {
          "expr": "rate(kubeevents_pod_total{namespace=\"$namespace\", pod=~\"$statefulset.*\"}[5m])",
          "legendFormat": "{{pod}} ({{type}})"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Warning Events on Pods (5m Increase)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "increase(kubeevents_pod_total{namespace=\"$namespace\", pod=~\"$statefulset.*\", type=\"Warning\"}[5m])",
          "legendFormat": "{{pod}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Events by Component",
      "datasource": "$datasource",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum by (component) (rate(kubeevents_involved_total{namespace=\"$namespace\", kind=\"StatefulSet\"}[5m]))",
          "legendFormat": "{{component}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Spike Detection",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 27, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "idelta(kubeevents_statefulset_total{namespace=\"$namespace\", statefulset=\"$statefulset\"}[5m])",
          "legendFormat": "Spike"
        }
      ]
    }
  ]
}
