{
  "title": "Job / CronJob Detail",
  "uid": "kube-job-cronjob-detail",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },

  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource"
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": "$datasource",
        "label": "Namespace",
        "query": "label_values(kubeevents_job_total, namespace)",
        "includeAll": true,
        "multi": true
      }
    ]
  },

  "panels": [

    {
      "type": "stat",
      "title": "Total Job Events",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "sum(kubeevents_job_total{namespace=~\"$namespace\"})" }
      ]
    },

    {
      "type": "stat",
      "title": "Job Warning Events",
      "datasource": "$datasource",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "sum(kubeevents_job_total{namespace=~\"$namespace\", type=\"Warning\"})" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      }
    },

    {
      "type": "stat",
      "title": "Total CronJob Events",
      "datasource": "$datasource",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "sum(kubeevents_cronjob_total{namespace=~\"$namespace\"})" }
      ]
    },

    {
      "type": "stat",
      "title": "CronJob Warning Events",
      "datasource": "$datasource",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "sum(kubeevents_cronjob_total{namespace=~\"$namespace\", type=\"Warning\"})" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      }
    },

    {
      "type": "timeseries",
      "title": "Job Events per Second",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "rate(kubeevents_job_total{namespace=~\"$namespace\"}[5m])",
          "legendFormat": "{{namespace}} / {{job}} ({{type}})"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "CronJob Events per Second",
      "datasource": "$datasource",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "rate(kubeevents_cronjob_total{namespace=~\"$namespace\"}[5m])",
          "legendFormat": "{{namespace}} / {{cronjob}} ({{type}})"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Job Events by Reason",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum by (reason, type) (rate(kubeevents_job_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{reason}} ({{type}})"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },

    {
      "type": "timeseries",
      "title": "CronJob Events by Reason",
      "datasource": "$datasource",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum by (reason, type) (rate(kubeevents_cronjob_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{reason}} ({{type}})"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },

    {
      "type": "timeseries",
      "title": "Job Failures (5m Increase)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "increase(kubeevents_job_total{namespace=~\"$namespace\", reason=~\"BackoffLimitExceeded|Failed|DeadlineExceeded\"}[5m])",
          "legendFormat": "{{namespace}} / {{job}} / {{reason}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Job Completions (5m Increase)",
      "datasource": "$datasource",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "increase(kubeevents_job_total{namespace=~\"$namespace\", reason=\"Completed\"}[5m])",
          "legendFormat": "{{namespace}} / {{job}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Warning Events — Jobs & CronJobs",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 7 },
      "targets": [
        {
          "expr": "increase(kubeevents_job_total{namespace=~\"$namespace\", type=\"Warning\"}[5m])",
          "legendFormat": "Job: {{namespace}} / {{job}} / {{reason}}"
        },
        {
          "expr": "increase(kubeevents_cronjob_total{namespace=~\"$namespace\", type=\"Warning\"}[5m])",
          "legendFormat": "CronJob: {{namespace}} / {{cronjob}} / {{reason}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Top Jobs by Event Count (5m)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 7 },
      "targets": [
        {
          "expr": "topk(10, sum by (namespace, job) (increase(kubeevents_job_total{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "{{namespace}} / {{job}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    }
  ]
}
